<Application x:Class="OPBlocksManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BrandAccent" Color="#0E7C66"/>
        <SolidColorBrush x:Key="BrandAccentDark" Color="#0A5E4D"/>
        <SolidColorBrush x:Key="PanelBg" Color="#F4F6F5"/>
        <SolidColorBrush x:Key="CardBorder" Color="#DDE3E1"/>

        <Style TargetType="Button" x:Key="AccentButton">
            <Setter Property="Background" Value="{StaticResource BrandAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrandAccentDark}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#B7C2BE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="GhostButton" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Background" Value="#6B7A76"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#54615E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#C7CFCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
