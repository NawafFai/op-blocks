<Window x:Class="OPBlocksManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OPBlocksManager"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="ONE PROCESS Blocks — Manager" Height="700" Width="980"
        MinHeight="580" MinWidth="840"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" Background="White"
        FlowDirection="{Binding L.FlowDir}">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BrandAccent}" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo hexagon -->
                <Grid Grid.Column="0" Width="46" Height="46" VerticalAlignment="Center">
                    <Polygon Stroke="White" StrokeThickness="2" Fill="Transparent" Stretch="Uniform"
                             Points="0.866,0.5 0,1 -0.866,0.5 -0.866,-0.5 0,-1 0.866,-0.5"/>
                    <TextBlock Text="OP" Foreground="White" FontWeight="Bold" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="{Binding L[AppTitle]}" Foreground="White" FontSize="21" FontWeight="Bold"/>
                    <TextBlock Text="{Binding L[AppSubtitle]}" Foreground="#DCEFEA" FontSize="11.5" Margin="0,2,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding L[EnableAspen]}" Command="{Binding EnableAspenCommand}"
                            Background="White" Foreground="{StaticResource BrandAccent}"
                            Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
                    <Button Content="{Binding L.LangButtonText}" Command="{Binding ToggleLanguageCommand}"
                            Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                    <Button Content="{Binding L[About]}" Command="{Binding AboutCommand}"
                            Style="{StaticResource GhostButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBg}" Padding="16,6" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding Status}" Foreground="#41504C" FontSize="12"/>
        </Border>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="140"/>
            </Grid.RowDefinitions>

            <!-- Detect -->
            <DockPanel Grid.Row="0">
                <TextBlock Text="{Binding L[DetectedTitle]}" FontSize="15" FontWeight="SemiBold" Foreground="#2C3835"/>
                <Button Content="{Binding L[Refresh]}" Command="{Binding RefreshCommand}" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" DockPanel.Dock="Right"/>
            </DockPanel>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Simulators}" Margin="0,8,0,14">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                CornerRadius="6" Padding="12,8" Margin="0,0,10,10" MinWidth="260">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="#22302C"/>
                                    <Border Background="#E1EAE7" CornerRadius="3" Padding="5,1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Bitness}" FontSize="10" Foreground="#3B4A46"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Version}" FontSize="11" Foreground="#5B6A66" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding Path}" FontSize="10" Foreground="#8A968F" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding L[LibraryTitle]}" FontSize="15" FontWeight="SemiBold" Foreground="#2C3835" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding Blocks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8"
                                        Padding="16,12" Margin="0,0,0,10" Background="White">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="46" Height="46" CornerRadius="8"
                                                Background="#E6F1EE" VerticalAlignment="Top" Padding="6">
                                            <Grid>
                                                <TextBlock Text="⬡" FontSize="24" Foreground="{StaticResource BrandAccent}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <svgc:SvgViewbox Source="{Binding IconUri}"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="12,0,12,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="#22302C"/>
                                                <Border Background="#EEF2F1" CornerRadius="3" Padding="6,1" Margin="8,1,0,0">
                                                    <TextBlock Text="{Binding Code}" FontSize="10" Foreground="#55635F" FontFamily="Consolas"/>
                                                </Border>
                                                <Border Background="{StaticResource BrandAccent}" CornerRadius="3" Padding="6,1" Margin="6,1,0,0"
                                                        Visibility="{Binding Milestone, Converter={x:Static local:EmptyToCollapsedConverter.Instance}}">
                                                    <TextBlock Text="{Binding Milestone}" FontSize="10" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#5B6A66"
                                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Ellipse Width="9" Height="9" Fill="{Binding StatusBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"
                                                           FontSize="12" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <Button Content="{Binding DataContext.L[Install], RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Style="{StaticResource AccentButton}" Width="104"
                                                    Command="{Binding InstallCommand}" IsEnabled="{Binding CanInstall}"/>
                                            <Button Content="{Binding DataContext.L[Remove], RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Style="{StaticResource GhostButton}" Width="104" Margin="0,6,0,0"
                                                    Command="{Binding RemoveCommand}" IsEnabled="{Binding CanRemove}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <TextBlock Grid.Row="3" Text="{Binding L[ActivityLog]}" FontSize="13" FontWeight="SemiBold" Foreground="#2C3835" Margin="0,10,0,4"/>
            <Border Grid.Row="4" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="6" Background="#1E2624">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,6">
                    <TextBox Text="{Binding Log, Mode=OneWay}" IsReadOnly="True" Background="Transparent" Foreground="#CFE3DC"
                             BorderThickness="0" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"
                             FlowDirection="LeftToRight"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
